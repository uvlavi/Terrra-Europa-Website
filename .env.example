# Copy to .env and fill in real values before deploying

# Auth — team access key
ACCESS_KEY=28061972

# Sender identity
FROM_EMAIL=yuval@terrra-europa.com
FROM_NAME=Yuval Lavi

# Email provider: resend | brevo | smtp
EMAIL_PROVIDER=resend

# Resend (https://resend.com — free 3,000/month)
# 1. Add terrra-europa.com domain, copy the two DNS records (SPF + DKIM)
# 2. Create API key, paste here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Brevo alternative (https://app.brevo.com — free 9,000/month)
# BREVO_API_KEY=xkeysib-xxxx

# SMTP fallback (Gmail app password, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
